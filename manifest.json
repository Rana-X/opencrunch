{
  "manifest_version": 3,
  "name": "OpenCrunch",
  "version": "0.1.0",
  "description": "Scrape the current Crunchbase results page and append the visible rows to Google Sheets.",
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": [
    "https://www.crunchbase.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/popup.html"
  },
  "action": {
    "default_title": "OpenCrunch"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["https://www.crunchbase.com/*"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
